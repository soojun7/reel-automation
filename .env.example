# Reel Automation Environment Variables
# Copy this file to .env and fill in your API keys

# Claude API Key (for script analysis)
CLAUDE_API_KEY=your_claude_api_key_here

# Runware API Key (for Grok image and video generation)
# Get yours at: https://runware.ai
RUNWARE_API_KEY=your_runware_api_key_here

# ElevenLabs API Key (for Korean TTS)
# Get yours at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Custom voice ID (default uses Korean male voice)
# ELEVENLABS_VOICE_ID=your_custom_voice_id

# Cloudflare R2 Storage (for video storage & combining)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev
