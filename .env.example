# Reel Automation Environment Variables
# Copy this file to .env and fill in your API keys

# Runware API Key (for Grok image and video generation)
# Get yours at: https://runware.ai
RUNWARE_API_KEY=your_runware_api_key_here

# ElevenLabs API Key (for Korean TTS)
# Get yours at: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Custom voice ID (default uses Korean male voice)
# ELEVENLABS_VOICE_ID=your_custom_voice_id
