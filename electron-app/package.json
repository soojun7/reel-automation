{
  "name": "reel-studio",
  "version": "1.0.0",
  "description": "AI 숏폼 영상 제작 스튜디오",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"cd renderer && npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "cd renderer && npm run build && electron-builder",
    "build:mac": "cd renderer && npm run build && electron-builder --mac",
    "build:win": "cd renderer && npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.reelstudio.app",
    "productName": "Reel Studio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "keywords": ["electron", "video", "ai", "shorts"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.2",
    "electron-store": "^8.1.0"
  }
}
